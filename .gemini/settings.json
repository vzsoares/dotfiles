{
    "general": {
        "preferredEditor": "neovim",
        "vimMode": true,
        "sessionRetention": {
            "enabled": true,
            "maxAge": "30d",
            "maxCount": 50,
            "warningAcknowledged": true
        },
        "previewFeatures": true
    },
    "security": {
        "auth": {
            "selectedType": "oauth-personal"
        }
    },
    "ui": {
        "theme": "Default",
        "hideContextSummary": false,
        "footer": {
            "hideModelInfo": false,
            "hideContextPercentage": false
        },
        "showModelInfoInChat": true,
        "showStatusInTitle": true,
        "inlineThinkingMode": "full"
    },
    "mcpServers": {
        "approvaServer": {
            "httpUrl": "https://api-dev.approvafacilapp.com.br/core/mcp/"
        },
        "approvaServer-local": {
            "httpUrl": "http://localhost:4000/mcp/"
        },
        "playwright": {
            "command": "npx",
            "args": [
                "-y",
                "@playwright/mcp@latest",
                "--caps=vision,pdf",
                "--browser=chrome"
            ]
        },
        "docs-openai": {
            "httpUrl": "https://developers.openai.com/mcp"
        }
    },
    "tools": {
        "enableToolOutputTruncation": false,
        "truncateToolOutputThreshold": -1,
        "shell": {
            "showColor": true
        }
    }
}
