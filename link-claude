#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_CLAUDE="$SCRIPT_DIR/.claude"
TARGET_DIR="$HOME/.claude"

# CLAUDE.md
rm -f "$TARGET_DIR/CLAUDE.md"
ln -s "$DOTFILES_CLAUDE/CLAUDE.md" "$TARGET_DIR/CLAUDE.md"
echo "linked CLAUDE.md"

# Settings
rm -f "$TARGET_DIR/settings.json"
ln -s "$DOTFILES_CLAUDE/settings.json" "$TARGET_DIR/settings.json"
echo "linked settings.json"

# Skills
mkdir -p "$TARGET_DIR/skills"

for skill in "$DOTFILES_CLAUDE/skills"/*/; do
  skill_name="$(basename "$skill")"
  rm -rf "$TARGET_DIR/skills/$skill_name"
  ln -s "$DOTFILES_CLAUDE/skills/$skill_name" "$TARGET_DIR/skills/$skill_name"
  echo "linked skills/$skill_name"
done

echo "done"
